    "generate:council-owl-escrow-key": "node scripts/generate-council-owl-escrow-keypair.mjs",
    "mint:devnet-nft": "node scripts/mint-devnet-nft.mjs",
    "prepare:owl-center-demo": "node scripts/prepare-owl-center-demo-collection.mjs",
    "prepare:sugar-deploy": "node --env-file=.env.local scripts/prepare-sugar-deploy-from-launch.mjs",
    "sugar:deploy": "node --env-file=.env.local scripts/sugar-deploy-collection.mjs",
    "build": "next build",
    "rebuild": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "normalize:nft-economics": "node --env-file=.env.local scripts/normalize-nft-raffle-economics.mjs",
