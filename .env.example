# Supabase (client-safe; no server secrets in NEXT_PUBLIC_*)
# Prefer new API keys (see https://supabase.com/docs/guides/api/api-keys):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy JWT anon key name (still read by lib/supabase-env.ts if publishable unset):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server: prefer secret key; legacy service_role JWT still works (SERVER ONLY – never expose to client)
SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional (Windows / corporate antivirus HTTPS scanning): PEM path for extra CA certs so Node can reach Supabase.
# Without this, server routes may return 500 with "fetch failed" / certificate errors in the server log.
# NODE_EXTRA_CA_CERTS=C:\path\to\your-extra-root-ca.pem

# One-off maintenance only: required together with --confirm-apply to run scripts/normalize-nft-raffle-economics.mjs --apply
# Never commit ALLOW_NFT_ECONOMICS_NORMALIZE=1 to shared env; set in the shell for a single command.
# ALLOW_NFT_ECONOMICS_NORMALIZE=1

# Raffle treasury (prefer server-only; do not put in NEXT_PUBLIC_*)
# Receives platform fee share from ticket sales, post-start cancellation fees (SOL), and OWL for community-giveaway boosts.
# NFT buyout bid deposits use funds escrow (FUNDS_ESCROW_SECRET_KEY), not this wallet.
RAFFLE_RECIPIENT_WALLET=your-solana-treasury-address
# Client builds need the same address for payment instructions (do not put the secret key in NEXT_PUBLIC_*):
# NEXT_PUBLIC_RAFFLE_RECIPIENT_WALLET=your-solana-treasury-address

# Treasury signing (SERVER ONLY – optional). Only needed for legacy buyout bids deposited to RAFFLE_RECIPIENT_WALLET
# before funds-escrow routing. New buyout bids use FUNDS_ESCROW_SECRET_KEY (see funds escrow section below).
# RAFFLE_RECIPIENT_SECRET_KEY=

# Funds escrow (SERVER ONLY – ticket proceeds + NFT buyout bid deposits). Generate: npm run generate:funds-escrow-key
# FUNDS_ESCROW_SECRET_KEY=

# Admin auth: Sign-In with Solana session signing (SERVER ONLY)
# Min 16 characters. Required for admin routes.
SESSION_SECRET=your-min-16-char-secret
# Or use AUTH_SECRET if you already have it
# AUTH_SECRET=your-secret

# Solana RPC — set NEXT_PUBLIC_SOLANA_RPC_URL for browser + server (see lib/solana-rpc-url.ts).
# Optional: SOLANA_RPC_URL overrides only the server primary RPC; omit it to use NEXT_PUBLIC_SOLANA_RPC_URL everywhere.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://...
# SOLANA_RPC_URL=

# Server-only: optional HTTP RPC for read-heavy JSON-RPC (getAccount, getParsedTokenAccountsByOwner, holder checks).
# Sends and transaction history still use resolveServerSolanaRpcUrl() (falls back to NEXT_PUBLIC_SOLANA_RPC_URL).
# SOLANA_RPC_READ_URL=https://solana.drpc.org

# --- Local dev: save Helius credits (optional) ---
# When NODE_ENV=development, these override NEXT_PUBLIC_SOLANA_RPC_URL for wallet + server JSON-RPC.
# Use any free HTTP endpoint — e.g. https://solana.drpc.org or https://api.mainnet-beta.solana.com (no paid provider required).
# Leave unset to use the normal NEXT_PUBLIC_SOLANA_RPC_URL (and optional SOLANA_RPC_URL if set) in dev.
# NEXT_PUBLIC_DEV_SOLANA_RPC_URL=https://solana.drpc.org
# Optional server-only dev URL (otherwise NEXT_PUBLIC_DEV_SOLANA_RPC_URL is used on the server in dev too):
# SOLANA_RPC_DEV_URL=

# --- Vercel Preview (branch deploys): save Helius credits ---
# Set these only in the Vercel "Preview" environment (not Production). Production keeps Helius on NEXT_PUBLIC_SOLANA_RPC_URL.
# next.config.js sets NEXT_PUBLIC_VERCEL_DEPLOY_ENV from VERCEL_ENV at build time so the client can pick preview RPC.
# NEXT_PUBLIC_PREVIEW_SOLANA_RPC_URL=https://solana.drpc.org
# Optional server-only preview URL (otherwise NEXT_PUBLIC_PREVIEW_SOLANA_RPC_URL is used for API routes too):
# SOLANA_RPC_PREVIEW_URL=https://solana.drpc.org
#
# Alternative without preview-specific vars: in Vercel, set NEXT_PUBLIC_SOLANA_RPC_URL to a free RPC under "Preview"
# scope only, and Helius under "Production" only.

# --- Wallet read RPC (production): cut Helius credits without changing behavior ---
# The wallet adapter Connection (balances, token accounts, sends) uses resolveWalletAdapterRpcUrl():
# optional NEXT_PUBLIC_WALLET_READ_RPC_URL overrides only that path. Cluster/explorer helpers still use
# NEXT_PUBLIC_SOLANA_RPC_URL. Set WALLET_READ to a reliable free HTTP endpoint (e.g. https://solana.drpc.org);
# keep NEXT_PUBLIC_SOLANA_RPC_URL as your Helius URL if you use it elsewhere, and keep HELIUS_API_KEY for DAS.
# Unset = wallet uses NEXT_PUBLIC_SOLANA_RPC_URL (same as before this option existed).
# NEXT_PUBLIC_WALLET_READ_RPC_URL=https://solana.drpc.org

# --- Helius / staying on a lower tier ---
# Helius charges RPC methods (getParsedTokenAccountsByOwner, getTransaction, …) on your RPC URL.
# This app also uses HELIUS_API_KEY for DAS on the server (NFT list, metadata, holder checks).
# Prefer routing browser wallet traffic via NEXT_PUBLIC_WALLET_READ_RPC_URL (above) and reserving Helius for
# HELIUS_API_KEY DAS + primary server RPC (NEXT_PUBLIC_SOLANA_RPC_URL or SOLANA_RPC_URL) when you need consistent getTransaction reads.
# HELIUS_API_KEY=

# Prize escrow (SERVER ONLY – never commit real key).
# You MUST have the secret key for the wallet that holds the NFTs. The public address alone is not enough.
# - If you created the escrow wallet: export its private key from your wallet app (e.g. Phantom: Settings → Security → Export Private Key). Paste as base58: PRIZE_ESCROW_SECRET_KEY=yourBase58String
# - To create a NEW escrow wallet: npm run generate:escrow-key then paste the printed line. Fund that address with SOL.
# Format: either JSON array of 64 numbers, or base58 secret key (no quotes for base58).
# PRIZE_ESCROW_SECRET_KEY=[1,2,...,64]
# PRIZE_ESCROW_SECRET_KEY=yourBase58PrivateKeyFromPhantom

# Frozen escrow SPL token account: verify-prize-deposit allows by default (raffle can go live; admin can send prize
# manually and record the tx). Set strict to block verify until thawed (legacy behavior):
# PRIZE_ESCROW_STRICT_FROZEN_SPL_VERIFY=true
# Or explicitly turn off bypass: PRIZE_ESCROW_ALLOW_FROZEN_SPL_DEPOSIT_VERIFY=false

# NFT raffles created before this instant (ISO 8601) skip the “must be in escrow” gate for public listing
# and ticket checkout (legacy raffles from before prize escrow existed). Omit = all NFT raffles need prize_deposited_at.
# Must be NEXT_PUBLIC_* so the browser and server use the same rule when loading /raffles.
# NEXT_PUBLIC_ESCROW_REQUIRED_SINCE=2025-06-01T00:00:00.000Z

# Optional: max rows for GET /raffles REST fetch (default 1000). Lower only if you need a smaller payload.
# RAFFLES_REST_LIST_LIMIT=1000

# Local dev (`next dev`): slower background polling + longer Owltopia holder cache to save Helius credits (see lib/dev-budget.ts).
# Set to 1 for production-style intervals when testing realtime behavior.
# NEXT_PUBLIC_DEV_FULL_POLLING=

# OWL token (optional) – when set, OWL appears as a raffle currency, Owl Council governance, and the Nesting OWL perch.
# Must be an SPL mint that exists on the **same** cluster as NEXT_PUBLIC_SOLANA_RPC_URL / wallet RPC (mainnet OWL + devnet RPC → “mint doesn’t exist” in Nesting and wallet reads).
NEXT_PUBLIC_OWL_MINT_ADDRESS=JA2gZuhy83CD71xQNMJCMHvTvhxFnVFerw5dYiyFkAfM
# OWL_DECIMALS=6

# --- Owl Nesting (NESTING_* server vars only) ---
# Full list with descriptions: see .env.nesting.example (use that file to copy into Vercel).
# Emergency / maintenance: true = stake, claim, unstake rejected; overrides admin “pause” toggle (see lib/nesting/policy.ts).
# NESTING_DISABLED=true
# Optional signer for freeze-backed Owl Nest NFT staking (MPL Core FreezeDelegate).
# Must be the collection/update/plugin authority for the Owl Nest Core collection.
# NESTING_NFT_FREEZE_AUTHORITY_WALLET=
# NESTING_NFT_FREEZE_AUTHORITY_SECRET_KEY=
# Optional server-side vault signer for on-chain OWL staking unstake releases.
# If omitted, falls back to COUNCIL_OWL_ESCROW_SECRET_KEY for the governance pool.
# NESTING_STAKE_VAULT_SECRET_KEY=

# --- Owl Council: OWL voting escrow (SERVER ONLY – never commit real key) ---
# When set, vote weight uses OWL users deposit into this wallet’s SPL token account (see migration 075).
# When unset, council voting uses wallet OWL balance / snapshots as before.
# Generate a NEW key (recommended): npm run generate:council-owl-escrow-key — paste the printed COUNCIL_OWL_ESCROW_SECRET_KEY line.
# Format: JSON array of 64 numbers, OR base58 secret key (same as PRIZE_ESCROW_SECRET_KEY).
# Fund the public address with SOL for fees. After deploy, users transfer OWL to this wallet’s OWL ATA.
# COUNCIL_OWL_ESCROW_SECRET_KEY=
# Optional: minimum OWL per deposit confirmation (default 1). UI + API enforce.
# COUNCIL_ESCROW_MIN_DEPOSIT_UI=1

# --- Owl Council: escrow → Owl Nesting (vote-weight cutoff) ---
# Optional announcement (ISO 8601): UI-only; start messaging before the hard cutoff below.
# OWL_COUNCIL_STAKE_MIGRATION_ANNOUNCE_ISO=
# NEXT_PUBLIC_OWL_COUNCIL_STAKE_MIGRATION_ANNOUNCE_ISO=
#
# HARD CUTOFF (ISO 8601): after this instant, /api/council/escrow/confirm-deposit returns 403; vote weight switches to OWL staked in the Nesting governance pool below. Set the same cutoff in NEXT_PUBLIC_* so banners/countdown stay in sync.
# OWL_COUNCIL_LEGACY_ESCROW_DEPOSIT_CUTOFF_AT=
# NEXT_PUBLIC_OWL_COUNCIL_LEGACY_ESCROW_DEPOSIT_CUTOFF_AT=
#
# staking_pools.slug for council votes after cutoff (default owl-council-governance). Pool must use the OWL mint and be activated when cutoff goes live (see migration 108).
# OWL_COUNCIL_GOVERNANCE_NESTING_POOL_SLUG=
#
# Ops-only: a **14-day** announce→cutoff window is typical so holders can withdraw escrow OWL and re-stake in Nesting (not enforced in code).

# Owltopia NFT collection (optional) – when set, creators who hold an NFT from this collection get 3% platform fee instead of 6%. Requires HELIUS_API_KEY.
# OWLTOPIA_COLLECTION_ADDRESS=
# Or: NEXT_PUBLIC_OWLTOPIA_COLLECTION_ADDRESS=

# Revenue thresholds (optional)
# REVENUE_THRESHOLD_SOL=0
# REVENUE_THRESHOLD_USDC=0

# Site URL for link previews (optional; default https://www.owltopia.xyz)
# NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Discord webhooks (optional, server-only). Create incoming webhooks: Server Settings → Integrations → Webhooks.
# Treat URLs like passwords: never NEXT_PUBLIC_*, never commit real URLs, rotate in Discord if leaked.
# Only https://discord.com/api/webhooks/... (or canary/ptb/discordapp) are accepted server-side.
# DISCORD_WEBHOOK_RAFFLE_CREATED=...  (new raffle in DB)
# DISCORD_WEBHOOK_RAFFLE_WINNER=...  (winner drawn)
# DISCORD_WEBHOOK_COMMUNITY_GIVEAWAY_WINNER=...  (admin draw for pool/community giveaway; optional — falls back to DISCORD_WEBHOOK_RAFFLE_WINNER)
# DISCORD_WEBHOOK_COMMUNITY_GIVEAWAY_OPEN=...     (pool giveaway opened for entries; optional — falls back to DISCORD_WEBHOOK_LIVE_RAFFLES then DISCORD_WEBHOOK_URL). Pings Discord user if the admin who created the giveaway linked Discord (dashboard).
# DISCORD_WEBHOOK_LIVE_RAFFLES=...   (manual “Post to Discord” from Owl Vision for active raffles)
# DISCORD_WEBHOOK_X_POSTS=...        (#x-post: admin mirrors @Owltopia_sol tweet via fixupx embed after Share on owltopia.xyz)
# DISCORD_RAID_ROLE_ID=1458816019282919569   (@raid role snowflake — used instead of @everyone on raid pings)
# DISCORD_WEBHOOK_OWL_COUNCIL_PROPOSAL_LIVE=...  (admin sets Owl Council proposal to active; proposer wallet, display name, Discord username if linked; pings linked Discord user)
# DISCORD_WEBHOOK_URL=...            (fallback for any of the above if the specific var is unset)

# Discord giveaway partners (paid communities): hashes API keys for POST /api/integrations/discord-giveaway/notify
# Optional; if unset, SESSION_SECRET (or AUTH_SECRET) is used — must be at least 16 characters.
# DISCORD_GIVEAWAY_PARTNER_API_PEPPER=long-random-string-only-for-partner-api-keys

# Discord slash commands + USDC partner flow (Interactions URL: https://<your-domain>/api/discord/interactions)
# DISCORD_APPLICATION_ID=...          # Application ID (OAuth2 → General)
# Optional: link Discord accounts on Dashboard (OAuth2 → Add redirect: https://<your-domain>/api/me/discord/callback)
# DISCORD_OAUTH_CLIENT_SECRET=...     # OAuth2 “Client Secret” (required for /api/me/discord/link)
# DISCORD_OAUTH_CLIENT_ID=...         # Override client id (defaults to DISCORD_APPLICATION_ID)
# DISCORD_OAUTH_REDIRECT_URI=...      # Override callback URL (default https://<NEXT_PUBLIC_SITE_URL>/api/me/discord/callback)
# DISCORD_PUBLIC_KEY=...               # Application “Public Key” (hex) for interaction signature verify
# DISCORD_BOT_TOKEN=...                # Bot token; used by register-commands route, Gen2 role claims, and optional REST
# Gen2 presale Discord role claims (server-side only — never expose bot token to the client)
# DISCORD_CLIENT_ID=...               # OAuth client id (alias: DISCORD_OAUTH_CLIENT_ID / DISCORD_APPLICATION_ID)
# DISCORD_CLIENT_SECRET=...           # OAuth secret (alias: DISCORD_OAUTH_CLIENT_SECRET)
# DISCORD_REDIRECT_URI=...            # OAuth callback (alias: DISCORD_OAUTH_REDIRECT_URI; default /api/me/discord/callback)
# DISCORD_GUILD_ID=...                # Owltopia Discord server id
# DISCORD_CHANNEL_PUBLIC=...            # #public-chat (…2736)
# DISCORD_CHANNEL_HOLDER=...            # #owls-chat (…2798)
# Optional fast path: Railway worker posts full messages over Gateway (instant, not letter-by-letter)
# DISCORD_BROADCAST_WORKER_URL=https://your-railway-service.up.railway.app
# DISCORD_BROADCAST_WORKER_SECRET=...   # Same value on Railway + Vercel; Bearer auth for POST /broadcast

# Discord reply bot (Railway worker: workers/discord-reply-bot — Message Content Intent required)
# Same DISCORD_BOT_TOKEN + DISCORD_GUILD_ID as above.
# DISCORD_REPLY_CHANNEL_IDS=public_id,holder_id   # e.g. …2736,…2798 (#public-chat, #owls-chat)
# DISCORD_REPLY_ENABLED=true
# DISCORD_REPLY_COOLDOWN_SEC=30
# OWLTOPIA_SITE_URL=https://www.owltopia.xyz
# DISCORD_GEN2_PRESALE_ROLE_ID=...    # Role granted after presale purchase + claim flow
# DISCORD_GEN2_WHITELIST_ROLE_ID=...  # Optional separate whitelist role (defaults to presale role id)
# DISCORD_BOT_USDC_TREASURY_WALLET=... # Solana address receiving partner USDC (or falls back to RAFFLE_RECIPIENT_WALLET)
# Optional:
# DISCORD_BOT_INVITE_URL=https://discord.com/api/oauth2/authorize?client_id=...&permissions=...&scope=bot%20applications.commands
# DISCORD_PARTNER_USDC_MINT=...        # Mainnet USDC mint if not default
# DISCORD_PARTNER_USDC_PRICE=50           # Catalog / month for Partner Pro Discord renewals when linked partner row has no quote (see migration 121 / partner_pro_monthly_quote_usdc)
# DISCORD_PARTNER_SUBSCRIPTION_DAYS=30
# DISCORD_PARTNER_PAYMENT_INTENT_TTL_HOURS=48

# Platform name (optional). When set, used in page titles, metadata, footer, wallet app identity, etc. Default: Owl Raffle
# NEXT_PUBLIC_PLATFORM_NAME=My Raffle Site

# Custom Open Graph image (optional). If unset, metadata uses /opengraph-image (Next.js generates PNG from app/opengraph-image.tsx). Override with a public/ path, e.g. /my-og.png (1200×630).
# NEXT_PUBLIC_OG_IMAGE=/my-og.png

# Raffle cancellation (optional). When creator requests cancellation and admin accepts in Owl Vision:
# Ticket buyers get refunds in all cases (treasury sends). Within 24h: no fee to host. After 24h: host is charged cancellation fee.
# FULL_REFUND_WINDOW_HOURS=24
# CANCELLATION_FEE_SOL=0.1

# Scam / spam NFT blocklist (optional). Blocked NFTs are hidden from the wallet NFT picker.
# Comma- or newline-separated list of mint and/or collection addresses (Solana base58).
# SCAM_NFT_BLOCKLIST=addr1,addr2,addr3
# Or a URL returning JSON: string[] or { addresses?: string[], mints?: string[], collections?: string[] }
# SCAM_NFT_BLOCKLIST_URL=https://your-list.com/blocklist.json

# Leaderboard (UTC): first calendar month (`YYYY-MM`) that uses draw-threshold rollup on month/year views.
# All-time stays on legacy rollup. Months before this keep original leaderboard counting. Default when unset: 2026-05.
# LEADERBOARD_NEW_RULES_EFFECTIVE_MONTH=2026-05
# Min raffle ticket_price (SOL); raffles at or below this are excluded (strict >). Default: 0.0001
# LEADERBOARD_MIN_TICKET_PRICE_SOL=0.0001
# Optional comma/newline-separated Solana wallets to hide from leaderboard (in addition to built-in founder/treasury list).
# LEADERBOARD_EXCLUDED_WALLETS=

# Referrals: set to false to stop persisting referrer on ticket rows (dry-run / abuse pause).
# Default when unset: enabled. Attribution uses an httpOnly cookie from GET /api/referrals/capture, not client JSON.
# REFERRAL_ATTRIBUTION_ENABLED=false
#
# One free ticket per buyer wallet (lifetime, any raffle) when they use a valid referral link: qty 1 only, no prior
# confirmed entry on that raffle, and they have never confirmed a referral free ticket before. Server token confirm (no chain pay).
# REFERRAL_COMPLIMENTARY_TICKET_ENABLED=true
#
# Anti-abuse (attribution + leaderboard min purchase defaults in code/SQL — keep in sync if you change SQL view 065):
# REFERRAL_MIN_PURCHASE_SOL=0.02
# REFERRAL_MIN_PURCHASE_USDC=1
# REFERRAL_MIN_PURCHASE_OWL=10
# Max rows with a referrer in 24h per buyer wallet (pending+confirmed); blocks referral spray.
# REFERRAL_MAX_BUYER_ROWS_24H=20
# Max rows with a referrer in 24h per referrer wallet (all buyers).
# REFERRAL_MAX_REFERRER_ROWS_24H=120

# --- Vercel Cron (production only) ---
# You do not "find" this in the Vercel UI — you invent it, then store it as an env var.
# 1) Generate a long random string (e.g. PowerShell: [guid]::NewGuid().ToString('N'); or openssl rand -hex 32).
# 2) Vercel → your Project → Settings → Environment Variables → add CRON_SECRET for Production (and Preview if you test crons there).
# 3) Redeploy. Vercel sends Authorization: Bearer <CRON_SECRET> when calling routes listed in vercel.json crons.
# Without CRON_SECRET set in the deployment, GET /api/cron/draw-ended-raffles returns 500 and scheduled winner draws never run.
# For local testing of the cron route, you can set the same value here and call the URL with Authorization: Bearer <value>.
CRON_SECRET=

# --- Owltopia Gen2 presale ---
# DB: apply migrations 093_gen2_presale.sql, 094_gen2_presale_settings.sql, 095_gen2_presale_gift_audit.sql (gift audit + RPC).
# Copy these into `.env.local` or Vercel and fill in values. RPC uses NEXT_PUBLIC_SOLANA_RPC_URL / SOLANA_RPC_URL above.
#
# Client-visible offer (defaults in code: 20 USDC, 657 spots if unset):
NEXT_PUBLIC_GEN2_PRESALE_PRICE_USDC=
NEXT_PUBLIC_GEN2_PRESALE_SUPPLY=
#
# Optional server-only overrides if you do not want NEXT_PUBLIC_* for price/supply:
# GEN2_PRESALE_PRICE_USDC=
# GEN2_PRESALE_SUPPLY=
#
# Revenue split — two SystemProgram.transfer instructions in one transaction (must sum to 100%):
FOUNDER_A_WALLET=
FOUNDER_B_WALLET=
FOUNDER_A_PERCENT=
FOUNDER_B_PERCENT=
# Leave both percents blank for 50/50; if you set one, set both so they sum to 100.
#
# Example Owltopia founder addresses (paste into FOUNDER_* above if these are correct):
# A: 7gra2JyY969Lt3BXLb6FMx9DxouXcEpRzpiKnc6wFgrq
# B: qg7pNNZq7qDQuc6Xkd1x4NvS2VM3aHtCqHEzucZxRGA
#
# Explorer links for success UI (default mainnet-beta if unset):
NEXT_PUBLIC_SOLANA_CLUSTER=
#
# Optional hero countdown on /gen2-presale (ISO 8601, UTC — e.g. Monday May 4, 2026 noon Eastern):
# NEXT_PUBLIC_GEN2_COUNTDOWN_ISO=2026-05-04T16:00:00.000Z
NEXT_PUBLIC_GEN2_COUNTDOWN_ISO=
#
# Extra operators for /admin/gen2-presale — comma-separated base58 (full DB admins always allowed):
ADMIN_WALLETS=
#
# Max presale spots per admin “gift credits” call (default 50; absolute cap 200 in code):
# GEN2_PRESALE_ADMIN_MAX_GIFT_QTY=

# --- Owltopia governance (Anchor program + /owl-council) ---
# Program id (PUBLIC only — safe as NEXT_PUBLIC_*). Matches `declare_id!` in governance-anchor; change if you redeployed with a new keypair.
# NEXT_PUBLIC_GOVERNANCE_PROGRAM_ID=FwEAjseYTP6vTp9g6SpBTgySWzm4yxCtBc3Ti7Rvcfyz

# Wallet (base58) that may run one-time Initialize on Owl Council; must match the connected wallet. Restart dev server after changing.
# NEXT_PUBLIC_GOVERNANCE_INIT_AUTHORITY=

# Dev only: any connected wallet can Initialize. Never true in production.
# NEXT_PUBLIC_GOVERNANCE_ALLOW_OPEN_INIT=false

# Where your governance PROGRAM keypair JSON FILE lives on disk — a path string only (SECRET — not read by Next.js).
# Do NOT paste the [1,2,3,...] array here; save it inside the .json file and point to that file.
# Recommended path (repo layout):
#   governance-anchor/keys/owltopia_governance-keypair.json
# Before `anchor build` or `anchor deploy`, copy to Anchor’s folder (or run npm run copy:governance-keypair):
#   governance-anchor/target/deploy/owltopia_governance-keypair.json
# GOVERNANCE_PROGRAM_KEYPAIR_PATH=governance-anchor/keys/owltopia_governance-keypair.json
#
# After setting the path, copy the file into Anchor’s deploy folder:
#   npm run copy:governance-keypair
