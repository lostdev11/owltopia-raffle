# Owl Nesting — SERVER ONLY. Paste these into Vercel (Production / Preview) as needed.
# Do not use NEXT_PUBLIC_* for any of these.

# Sellout gate before staking is allowed (see lib/nesting/policy.ts)
NESTING_SELL_OUT_REQUIRED=true
NESTING_SELL_OUT_REACHED=false
# NESTING_SELL_OUT_AT=2026-12-31T00:00:00.000Z

# Must equal reward_rate on each NFT nesting perch (canonical migration uses 1)
NESTING_OWL_DAILY_REWARD_PER_NFT=1

# Metaplex Core custody — public escrow wallet (from npm run generate:nesting-escrow-keypair)
NESTING_ESCROW_WALLET_ADDRESS=
# Signing key for that wallet (JSON byte array or base58) when on-chain txs use it
NESTING_ESCROW_SECRET_KEY=

# OWL payouts for claims — public treasury + signing keypair
NESTING_OWL_REWARD_TREASURY_WALLET=
NESTING_OWL_REWARD_TREASURY_SECRET_KEY=
# Allow claims to update the DB only (no SPL transfer). Default off — omit unless you need MVP-style testing.
# NESTING_ALLOW_DB_ONLY_OWL_CLAIMS=true

# OWL token staking vault signer. Required for on-chain unstake releases.
# For the Council governance perch, this can be the same key as COUNCIL_OWL_ESCROW_SECRET_KEY.
NESTING_STAKE_VAULT_SECRET_KEY=

# Collection fallback when staking_pools.collection_key is unset (optional if DB has collection_key).
# Canonical Owl Nest collection (must match staking_pools.collection_key for owl-nest-365 after migration 106).
NESTING_OWLTOPIA_COIN_COLLECTION_ADDRESS=EZdgJQao3v33F723EsC1QqfwvuDRyVkCMsZTW8Z6JTpB
